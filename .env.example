# Axelarscan UI - Environment Variables
# Copy this file to .env and fill in the values for your target environment.
# For deployment-specific values, set them in the Vercel dashboard per project.

# Environment: mainnet | testnet | staging | stagenet | devnet-amplifier
NEXT_PUBLIC_ENVIRONMENT=mainnet

# Application URL
NEXT_PUBLIC_APP_URL=https://axelarscan.io

# Status message (leave empty for no banner)
NEXT_PUBLIC_STATUS_MESSAGE=

# API endpoints
NEXT_PUBLIC_AXELARSCAN_API_URL=
NEXT_PUBLIC_VALIDATOR_API_URL=
NEXT_PUBLIC_TOKEN_TRANSFER_API_URL=
NEXT_PUBLIC_GMP_API_URL=

# RPC / LCD endpoints
NEXT_PUBLIC_RPC_URL=
NEXT_PUBLIC_LCD_URL=

# Analytics (optional)
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA_TRACKING_ID=

# ENS (The Graph subgraph)
NEXT_PUBLIC_ENS_SUBGRAPH_URL=

# Third-party integrations
NEXT_PUBLIC_INTERCOM_APP_ID=
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_XAMAN_API_KEY=

# SEO
NEXT_PUBLIC_DEFAULT_TITLE=Axelarscan | Axelar Network Explorer
NEXT_PUBLIC_DEFAULT_DESCRIPTION=Axelarscan lets you explore and search for metrics and activities taking place on Axelar Network, including transactions, addresses, validators, etc.
